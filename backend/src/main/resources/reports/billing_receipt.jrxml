<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports https://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="billing_receipt" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <parameter name="patientName" class="java.lang.String"/>
    <parameter name="regNo" class="java.lang.String"/>
    <parameter name="age" class="java.lang.String"/>
    <parameter name="gender" class="java.lang.String"/>
    <parameter name="mobile" class="java.lang.String"/>
    <parameter name="refDoctor" class="java.lang.String"/>
    <parameter name="center" class="java.lang.String"/>
    <parameter name="receiptDate" class="java.lang.String"/>
    <parameter name="paymentType" class="java.lang.String"/>
    <parameter name="totalAmount" class="java.lang.String"/>
    <parameter name="discountAmount" class="java.lang.String"/>
    <parameter name="netAmount" class="java.lang.String"/>
    <parameter name="paidAmount" class="java.lang.String"/>
    <parameter name="balanceAmount" class="java.lang.String"/>
    <parameter name="receiptNo" class="java.lang.String"/>

    <field name="testName" class="java.lang.String"/>
    <field name="rate" class="java.lang.String"/>

    <title>
        <band height="160">
            <!-- Header -->
            <rectangle>
                <reportElement x="0" y="0" width="535" height="55" backcolor="#0D2137"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="6" width="535" height="22" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true" fontName="DejaVu Sans"/>
                </textElement>
                <text><![CDATA[AwaleMediSoft Laboratory]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="30" width="535" height="14" forecolor="#A8CDE6"/>
                <textElement textAlignment="Center">
                    <font size="9" fontName="DejaVu Sans"/>
                </textElement>
                <text><![CDATA[Billing Receipt]]></text>
            </staticText>

            <!-- Receipt No -->
            <textField>
                <reportElement x="380" y="58" width="155" height="14"/>
                <textElement textAlignment="Right"><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Receipt No: " + $P{receiptNo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="74" width="155" height="14"/>
                <textElement textAlignment="Right"><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Date: " + $P{receiptDate}]]></textFieldExpression>
            </textField>

            <!-- Patient Info -->
            <rectangle>
                <reportElement x="0" y="58" width="370" height="65" backcolor="#F0F7FC"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#B8D0E4"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="5" y="62" width="360" height="14"/>
                <textElement><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Patient: " + $P{patientName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="5" y="78" width="180" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Reg No: " + $P{regNo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="190" y="78" width="175" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Age/Gender: " + $P{age} + " / " + $P{gender}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="5" y="94" width="180" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Mobile: " + $P{mobile}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="190" y="94" width="175" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Ref Doctor: " + $P{refDoctor}]]></textFieldExpression>
            </textField>

            <!-- Divider -->
            <line>
                <reportElement x="0" y="128" width="535" height="1" forecolor="#B8D0E4"/>
            </line>

            <!-- Payment type -->
            <textField>
                <reportElement x="5" y="135" width="260" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["Payment Mode: " + $P{paymentType} + "    Center: " + $P{center}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="24" backcolor="#122D4A"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="5" y="5" width="380" height="14" forecolor="#FFFFFF"/>
                <textElement><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[TEST / SERVICE]]></text>
            </staticText>
            <staticText>
                <reportElement x="390" y="5" width="140" height="14" forecolor="#FFFFFF"/>
                <textElement textAlignment="Right"><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[AMOUNT (₹)]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="5" y="3" width="380" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$F{testName}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="390" y="3" width="140" height="14"/>
                <textElement textAlignment="Right"><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA[$F{rate} != null ? $F{rate} : "0"]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="120">
            <line>
                <reportElement x="0" y="5" width="535" height="1" forecolor="#0D2137"/>
            </line>
            <!-- Summary Box -->
            <rectangle>
                <reportElement x="300" y="10" width="235" height="100" backcolor="#F0F7FC"/>
                <graphicElement><pen lineWidth="0.5" lineColor="#B8D0E4"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="305" y="14" width="130" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Total Amount:]]></text>
            </staticText>
            <textField>
                <reportElement x="435" y="14" width="95" height="14"/>
                <textElement textAlignment="Right"><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["₹ " + $P{totalAmount}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="305" y="32" width="130" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Discount:]]></text>
            </staticText>
            <textField>
                <reportElement x="435" y="32" width="95" height="14"/>
                <textElement textAlignment="Right"><font size="9" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["₹ " + $P{discountAmount}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="305" y="50" width="130" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Net Amount:]]></text>
            </staticText>
            <textField>
                <reportElement x="435" y="50" width="95" height="14"/>
                <textElement textAlignment="Right"><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["₹ " + $P{netAmount}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="305" y="68" width="130" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Paid Amount:]]></text>
            </staticText>
            <textField>
                <reportElement x="435" y="68" width="95" height="14"/>
                <textElement textAlignment="Right"><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["₹ " + $P{paidAmount}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="305" y="86" width="130" height="14"/>
                <textElement><font size="9" fontName="DejaVu Sans"/></textElement>
                <text><![CDATA[Balance:]]></text>
            </staticText>
            <textField>
                <reportElement x="435" y="86" width="95" height="14"/>
                <textElement textAlignment="Right"><font size="9" isBold="true" fontName="DejaVu Sans"/></textElement>
                <textFieldExpression><![CDATA["₹ " + $P{balanceAmount}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

    <pageFooter>
        <band height="30">
            <line>
                <reportElement x="0" y="0" width="535" height="1" forecolor="#B8D0E4"/>
            </line>
            <staticText>
                <reportElement x="0" y="5" width="535" height="14" forecolor="#5A7A9A"/>
                <textElement textAlignment="Center">
                    <font size="8" fontName="DejaVu Sans"/>
                </textElement>
                <text><![CDATA[AwaleMediSoft Laboratory — Thank you for choosing our services]]></text>
            </staticText>
        </band>
    </pageFooter>
</jasperReport>
